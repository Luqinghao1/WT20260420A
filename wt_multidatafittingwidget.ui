  </property>
  <property name="windowTitle">
   <string>多数据试井拟合子页</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* 模块整体作为统一白色工作区 */
#WT_MultidataFittingWidget {
    background-color: #ffffff;
    color: #333333;
    font-family: &quot;Microsoft YaHei&quot;;
}

/* 内部容器默认透明，避免白块拼接 */
QWidget#plotContainer, QWidget#leftPanelWidget {
    background-color: transparent;
    border: none;
}

/* 按钮通用样式 */
QPushButton {
    border: 1px solid #cccccc;
    border-radius: 4px;
    padding: 5px;
    background-color: #f9f9f9;
}
QPushButton:hover {
    background-color: #f0f0f0;
    border-color: #0078d7;
}
QPushButton:pressed {
    background-color: #e0e0e0;
}

/* 标题栏样式 */
QLabel#label_1, QLabel#label_2, QLabel#label_3 {
    font-weight: bold;
    font-size: 14px;
    color: #333;
    border-bottom: 2px solid #e0e0e0;
    padding-bottom: 3px;
    margin-top: 5px;
}
</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout_Main">
   <property name="spacing">
    <number>0</number>
