  <property name="styleSheet">
   <string notr="true">/* 全局设置 */
QWidget {
    background-color: #FFFFFF;
    color: #333333;
    font-family: &quot;Microsoft YaHei&quot;, sans-serif;
    font-size: 13px;
}

/* 顶部操作区 */
QWidget#topPanel {
    background-color: #FFFFFF;
    border: none;
}

/* 底部信息栏 */
QWidget#bottomPanel {
    background-color: #FAFAFA;
    border-top: 1px solid #E8E8E8;
}

/* 将按键样式改为更纯净的工具栏样式 */
QToolButton {
    background-color: transparent;
    border: none;
    border-radius: 4px;
    padding: 5px;
    color: #333333;
    font-weight: bold;
    font-size: 12px;
}
QToolButton:hover {
    background-color: #E6F7FF;
    color: #1890FF;
}
QToolButton:pressed {
    background-color: #BAE7FF;
}
QToolButton:disabled {
    color: #CCCCCC;
}

/* QTabWidget 样式优化：解决遮挡问题 */
QTabWidget::pane {
    border: none;
    /* 取消 pane 自己的上边框，因为我们用专门的 QFrame 来画分割线了 */
    border-top: 0px solid #D9D9D9;
    background: #FFFFFF;
}

QTabBar::tab {
    background: #FFFFFF;
    /* 增加上边框，和背景融为一体，起到占位作用，防止文字太贴近顶线 */
    border-top: 1px solid transparent;
    border-left: 1px solid transparent;
    border-right: 1px solid transparent;
    border-bottom: 2px solid transparent;
    padding: 8px 20px;
    min-width: 80px;
    color: #666666;
    margin-right: 2px;
    /* 增加 top margin，让标签页整体往下沉一点点，留出上方黑线的位置 */
    margin-top: 2px;
}

QTabBar::tab:selected {
    color: #1890FF;
    font-weight: bold;
    border-bottom: 2px solid #1890FF;
    background-color: #E6F7FF;
}

QTabBar::tab:hover {
    color: #40A9FF;
}

/* 底部标签 */
QLabel#filePathLabel {
    color: #666666;
    font-weight: bold;
}
QLabel#statusLabel {
    color: #999999;
}
</string>
